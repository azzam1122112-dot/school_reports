# Example environment variables for school_reports
# Copy to .env locally, and set the same keys in Render/production.
# DO NOT commit real secrets.

# -----------------
# Django
# -----------------
ENV=development
DEBUG=True
SECRET_KEY=unsafe-secret

# Comma-separated (no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# - local dev default uses SQLite if DATABASE_URL is empty
# - Postgres example:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# -----------------
# Redis (Celery broker + optional cache)
# -----------------
# If you don't have Redis in dev, you can leave it empty.
REDIS_URL=
# Optional: separate cache Redis URL
REDIS_CACHE_URL=

# -----------------
# Cloudflare R2 (S3-compatible media storage)
# -----------------
# Required to enable R2:
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=school-reports

# IMPORTANT: endpoint WITHOUT bucket name, e.g.
# https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=

# Optional: public domain for serving media (custom domain or *.r2.dev)
R2_PUBLIC_DOMAIN=

# Optional: if bucket is private and you want signed URLs
# AWS_QUERYSTRING_AUTH=1
AWS_QUERYSTRING_AUTH=0

# -----------------
# Optional: security hardening
# -----------------
CSP_ENABLED=0
CSP_REPORT_ONLY=1
# CONTENT_SECURITY_POLICY=default-src 'self'; ...

# -----------------
# Logging
# -----------------
LOG_LEVEL=INFO

# -----------------
# Email (for daily manager reports)
# -----------------
# Dev default in settings is console backend; production default is SMTP.
EMAIL_BACKEND=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
DEFAULT_FROM_EMAIL=no-reply@tawtheeq-ksa.com

# -----------------
# Daily manager report (2:00 PM by default)
# -----------------
DAILY_MANAGER_REPORT_ENABLED=1
DAILY_MANAGER_REPORT_INAPP_ENABLED=1
DAILY_MANAGER_REPORT_EMAIL_ENABLED=0
DAILY_MANAGER_REPORT_WHATSAPP_ENABLED=0
DAILY_MANAGER_REPORT_HOUR=14
DAILY_MANAGER_REPORT_MINUTE=0

# WhatsApp webhook (optional)
# Expected JSON payload with: channel, to, message, school_id, school_name, report_date, metrics
DAILY_MANAGER_REPORT_WHATSAPP_WEBHOOK_URL=
DAILY_MANAGER_REPORT_WHATSAPP_WEBHOOK_TOKEN=
DAILY_MANAGER_REPORT_WHATSAPP_TIMEOUT_SECONDS=10
